rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacherOwner(teacherId) {
      return request.auth != null && request.auth.uid == teacherId;
    }
    function isSignedIn() {
      return request.auth != null;
    }

    // 공통 메시지 생성/수정 규칙. otherRole은 'parent' 또는 'student' - 교사가 아닌
    // 상대방이 이 채널에서 어떤 sender 값을 써야 하는지를 나타낸다.
    function canCreateMessage(teacherId, otherRole) {
      return isSignedIn()
        && request.resource.data.keys().hasOnly(
             ['sender', 'originalText', 'originalLang', 'translatedText', 'englishGloss', 'status', 'createdAt'])
        && request.resource.data.originalText is string
        && request.resource.data.originalText.size() > 0
        && request.resource.data.originalText.size() < 2000
        && request.resource.data.createdAt == request.time
        && (
             ( isTeacherOwner(teacherId)
               && request.resource.data.sender == 'teacher'
               && request.resource.data.originalLang == 'ko'
               && (
                    (request.resource.data.status == 'pending'
                     && request.resource.data.translatedText == null)
                    ||
                    (request.resource.data.status == 'translated'
                     && request.resource.data.translatedText is string)
                  )
             )
             ||
             ( !isTeacherOwner(teacherId)
               && request.resource.data.sender == otherRole
               && request.resource.data.originalLang == 'th'
               && request.resource.data.status == 'pending'
               && request.resource.data.translatedText == null
             )
           );
    }

    function canUpdateMessage(teacherId, otherRole) {
      return isSignedIn()
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['translatedText', 'englishGloss', 'status'])
        && request.resource.data.translatedText is string
        && request.resource.data.status in ['translated', 'error']
        && (
             (isTeacherOwner(teacherId) && resource.data.sender == 'teacher')
             || (!isTeacherOwner(teacherId) && resource.data.sender == otherRole)
           );
    }

    match /teachers/{teacherId} {
      // 학부모/학생 환영 화면에서 교사 이름을 보여주기 위해, 로그인(익명 포함)한 누구나 단건 조회는 가능.
      // 이 문서에는 email 등 민감정보를 절대 넣지 않는다 (index.html 데이터 모델 참고).
      allow get: if isSignedIn();

      // 전체 교사 목록을 열거할 수 없도록 list는 항상 차단.
      allow list: if false;

      allow create: if isTeacherOwner(teacherId)
                    && request.resource.data.keys().hasOnly(['displayName', 'createdAt'])
                    && request.resource.data.displayName is string
                    && request.resource.data.createdAt == request.time;

      allow update: if isTeacherOwner(teacherId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']);

      allow delete: if false;

      match /students/{studentId} {
        // studentId는 추측 불가능한 Firestore auto-ID이므로, 초대 링크로 이미 id를 아는
        // 학부모/학생은 해당 문서를 get할 수 있다. 단 list는 교사 본인만 허용 -> 다른 학생
        // 목록을 열거하는 것을 원천 차단하는 핵심 방어선.
        allow get: if isTeacherOwner(teacherId) || isSignedIn();
        allow list: if isTeacherOwner(teacherId);

        allow create, update: if isTeacherOwner(teacherId)
          && request.resource.data.keys().hasOnly(['name', 'parentName', 'createdAt'])
          && request.resource.data.name is string;

        allow delete: if isTeacherOwner(teacherId);

        // 학부모와의 대화. 이 규칙에 도달하려면 teacherId와 studentId를 이미 알아야 하므로
        // (=학부모 초대 링크 보유), 교사 본인 또는 그 링크를 가진 (익명 인증된) 학부모가
        // 읽고 쓸 수 있다. 학생용 대화(studentMessages)와는 완전히 분리된 하위 컬렉션이다.
        match /parentMessages/{messageId} {
          allow get, list: if isTeacherOwner(teacherId) || isSignedIn();
          allow create: if canCreateMessage(teacherId, 'parent');
          allow update: if canUpdateMessage(teacherId, 'parent');
          // 대화 기록은 그 외에는 수정/삭제 불가 (사실상 불변 기록으로 유지).
          allow delete: if false;
        }

        // 학생 본인과의 대화. parentMessages와 동일한 규칙 구조이나 sender가 'student'여야 한다.
        match /studentMessages/{messageId} {
          allow get, list: if isTeacherOwner(teacherId) || isSignedIn();
          allow create: if canCreateMessage(teacherId, 'student');
          allow update: if canUpdateMessage(teacherId, 'student');
          allow delete: if false;
        }
      }
    }
  }
}
